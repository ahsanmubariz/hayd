---
import { revokeSession, verifySessionId } from '@/lib/auth/session';

export const prerender = false;

const signedSessionId = Astro.cookies.get('hayd_session')?.value;
if (signedSessionId) {
  const sessionId = await verifySessionId(signedSessionId);
  if (sessionId) {
    await revokeSession(sessionId);
  }
}
Astro.cookies.delete('hayd_session', {
  path: '/',
  httpOnly: true,
  sameSite: 'lax',
  secure: import.meta.env.PROD,
});
Astro.cookies.delete('hayd_csrf', {
  path: '/',
  sameSite: 'lax',
  secure: import.meta.env.PROD,
});
return Astro.redirect('/login');
