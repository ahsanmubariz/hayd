---
import AppShell from '@/layouts/AppShell.astro';
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card';
import { Input } from '@/components/ui/input';
import { Button } from '@/components/ui/button';
import { Alert } from '@/components/ui/alert';
import { PrivacyCard } from '@/components/app/privacy-card';
import { findProfile, findPasskeysByUser, findPasskeyById, deletePasskey } from '@/lib/db/client';
import { updateUserProfile, changePassword } from '@/lib/modules/users/service';
import { translate } from '@/lib/i18n/use-translation';
import { getCsrfToken, validateCsrf } from '@/lib/auth/csrf';

export const prerender = false;

const csrfToken = getCsrfToken(Astro);

const user = Astro.locals.user!;
const profile = await findProfile(user.id);
const passkeys = await findPasskeysByUser(user.id);

let success = '';
let errors: Record<string, string> = {};

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  if (!validateCsrf(Astro, Astro.request, formData)) {
    errors = { form: 'Invalid CSRF token' };
  } else {
    const action = String(formData.get('action') ?? '');

    try {
      if (action === 'profile') {
        await updateUserProfile(user.id, {
          displayName: String(formData.get('displayName') ?? ''),
          timezone: String(formData.get('timezone') ?? 'Asia/Jakarta'),
        });
        success = translate('profile.profile_updated');
      } else if (action === 'password') {
        await changePassword(user.id, {
          currentPassword: String(formData.get('currentPassword') ?? ''),
          newPassword: String(formData.get('newPassword') ?? ''),
        });
        success = translate('profile.password_updated');
      } else if (action === 'delete-passkey') {
        const passkeyId = String(formData.get('passkeyId') ?? '');
        if (passkeyId) {
          const pk = await findPasskeyById(passkeyId);
          if (pk && pk.user_id === user.id) {
            await deletePasskey(passkeyId);
            success = 'Passkey deleted successfully';
          }
        }
      }
    } catch (err) {
      if (err && typeof err === 'object' && 'fieldErrors' in err) {
        errors = (err as { fieldErrors: Record<string, string> }).fieldErrors;
      }
    }
  }
}
---

<AppShell title="Profile" activeRoute="profile" headerTitle={translate('nav.profile')} headerSubtitle={translate('profile.manage_account')}>
  <div class="space-y-4 p-4">
    {success && <Alert variant="success">{success}</Alert>}

    {/* Account Info Card */}
    <Card>
      <CardHeader className="pb-2">
        <div className="flex items-center gap-3">
          <div className="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-lg font-bold text-primary">
            {user.email.charAt(0).toUpperCase()}
          </div>
          <div>
            <p className="font-medium text-foreground">{profile?.display_name || user.email.split('@')[0]}</p>
            <p className="text-xs text-muted-foreground">{user.email}</p>
          </div>
        </div>
      </CardHeader>
      <CardContent>
        <div className="flex items-center gap-2 text-xs text-muted-foreground">
          <span className="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2 py-0.5 font-medium text-primary capitalize">{user.role}</span>
          <span>·</span>
          <span>{translate('profile.member_since')} {new Date().toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
        </div>
      </CardContent>
    </Card>

    {/* Profile Form */}
    <form method="POST">
      <input type="hidden" name="action" value="profile" />
      <input type="hidden" name="_csrf" value={csrfToken} />
      <Card>
        <CardHeader className="pb-2">
          <CardTitle className="text-sm">{translate('profile.personal_info')}</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3">
          <Input
            name="displayName"
            label={translate('profile.display_name')}
            placeholder={translate('profile.display_name_placeholder')}
            defaultValue={profile?.display_name ?? ''}
            error={errors.displayName}
          />
          <Input
            name="timezone"
            label={translate('profile.timezone')}
            defaultValue={profile?.timezone ?? 'Asia/Jakarta'}
            error={errors.timezone}
          />
          <Button type="submit">{translate('profile.save_profile')}</Button>
        </CardContent>
      </Card>
    </form>

    {/* Password Form */}
    <form method="POST">
      <input type="hidden" name="action" value="password" />
      <input type="hidden" name="_csrf" value={csrfToken} />
      <Card>
        <CardHeader className="pb-2">
          <CardTitle className="text-sm">{translate('profile.change_password')}</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3">
          <Input
            type="password"
            name="currentPassword"
            label={translate('profile.current_password')}
            autoComplete="current-password"
            error={errors.currentPassword}
          />
          <Input
            type="password"
            name="newPassword"
            label={translate('profile.new_password')}
            autoComplete="new-password"
            error={errors.newPassword}
          />
          <Button type="submit" variant="outline">{translate('profile.update_password')}</Button>
        </CardContent>
      </Card>
    </form>

    {/* Passkeys Card */}
    <Card>
      <CardHeader className="pb-2">
        <CardTitle className="text-sm">Passkeys (WebAuthn)</CardTitle>
      </CardHeader>
      <CardContent className="space-y-4">
        <p className="text-xs text-muted-foreground">
          Passkeys allow you to sign in securely using biometrics (like Touch ID or Face ID), a PIN, or a security key, without typing a password.
        </p>

        {passkeys.length > 0 ? (
          <div class="divide-y divide-border rounded-md border border-border bg-card text-card-foreground">
            {passkeys.map((pk) => (
              <div class="flex items-center justify-between p-3 text-xs">
                <div>
                  <p class="font-medium text-foreground">Passkey</p>
                  <p class="text-muted-foreground text-[10px] font-mono">
                    ID: {pk.id.substring(0, 8)}...{pk.id.substring(pk.id.length - 8)}
                  </p>
                  <p class="text-[10px] text-muted-foreground">
                    Created: {new Date(pk.created_at).toLocaleDateString()}
                  </p>
                </div>
                <form method="POST" style="display:inline">
                  <input type="hidden" name="action" value="delete-passkey" />
                  <input type="hidden" name="passkeyId" value={pk.id} />
                  <input type="hidden" name="_csrf" value={csrfToken} />
                  <Button type="submit" variant="destructive" size="sm" className="h-7 px-2.5 text-[10px]">
                    Delete
                  </Button>
                </form>
              </div>
            ))}
          </div>
        ) : (
          <p className="text-xs text-muted-foreground italic">No passkeys registered yet.</p>
        )}

        <Button id="register-passkey-btn" type="button" variant="outline" className="w-full text-xs">
          Register New Passkey
        </Button>
        <div id="passkey-error" class="hidden text-xs text-destructive mt-2"></div>
      </CardContent>
    </Card>

    {/* Privacy */}
    <PrivacyCard client:load />

    {/* Logout */}
    <Card>
      <CardContent className="py-3">
        <a href="/logout">
          <Button variant="destructive" className="w-full" size="sm">{translate('profile.sign_out')}</Button>
        </a>
      </CardContent>
    </Card>
  </div>
</AppShell>

<script>
  import { startRegistration } from '@simplewebauthn/browser';

  const registerBtn = document.getElementById('register-passkey-btn');
  const errorDiv = document.getElementById('passkey-error');

  if (registerBtn) {
    registerBtn.addEventListener('click', async () => {
      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.textContent = '';
      }
      registerBtn.disabled = true;
      const originalText = registerBtn.textContent;
      registerBtn.textContent = 'Registering...';

      try {
        // 1. Get options from server
        const optionsRes = await fetch('/api/passkey/register/options');
        if (!optionsRes.ok) {
          throw new Error('Failed to get registration options');
        }
        const options = await optionsRes.json();

        // 2. Start registration in browser
        const credential = await startRegistration({ optionsJSON: options });

        // 3. Verify on server
        const verifyRes = await fetch('/api/passkey/register/verify', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(credential),
        });

        const verifyResult = await verifyRes.json();
        if (!verifyRes.ok || !verifyResult.verified) {
          throw new Error(verifyResult.error || 'Verification failed');
        }

        // 4. Reload page on success
        window.location.reload();
      } catch (err: any) {
        console.error(err);
        if (errorDiv) {
          errorDiv.textContent = err.message || 'An error occurred during passkey registration.';
          errorDiv.classList.remove('hidden');
        }
        registerBtn.disabled = false;
        registerBtn.textContent = originalText;
      }
    });
  }
</script>
