---
import AdminShell from '@/layouts/AdminShell.astro';
import { Card } from '@/components/ui/card';
import { UserTable } from '@/components/admin/user-table';
import { listUsers } from '@/lib/modules/users/repository';

export const prerender = false;

const url = new URL(Astro.request.url);
const search = url.searchParams.get('search') ?? '';
const status = url.searchParams.get('status') ?? '';

let users = await listUsers();
if (search) {
  const q = search.toLowerCase();
  users = users.filter((u) => u.email.toLowerCase().includes(q));
}
if (status) {
  users = users.filter((u) => u.status === status);
}
---

<AdminShell title="Users" activeRoute="users">
  <div class="space-y-4">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-lg font-semibold text-foreground">Users</h1>
        <p class="text-sm text-muted-foreground">{users.length} user{users.length !== 1 ? 's' : ''} found</p>
      </div>
      <a href="/admin/users/new" class="rounded-xl bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 shrink-0">
        + Add user
      </a>
    </div>

    <!-- Search & filter: plain HTML form, works without JS -->
    <form method="GET" action="/admin/users">
      <Card>
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="flex-1">
            <label for="search" class="mb-1 block text-xs font-medium text-muted-foreground">Search</label>
            <input
              type="text"
              id="search"
              name="search"
              placeholder="Search by email..."
              value={search}
              class="h-10 w-full rounded-xl border border-border bg-background px-3 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
            />
          </div>
          <div class="sm:w-44">
            <label for="status" class="mb-1 block text-xs font-medium text-muted-foreground">Status</label>
            <select
              id="status"
              name="status"
              value={status}
              class="h-10 w-full rounded-xl border border-border bg-background px-3 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-ring"
            >
              <option value="">All statuses</option>
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
              <option value="deleted">Deleted</option>
            </select>
          </div>
          <div class="flex items-end">
            <button
              type="submit"
              class="h-10 rounded-xl bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
            >
              Filter
            </button>
          </div>
        </div>
      </Card>
    </form>

    <Card className="overflow-hidden p-0">
      <UserTable
        users={users}
        viewHrefPrefix="/admin/users"
        client:load
      />
    </Card>
</AdminShell>
