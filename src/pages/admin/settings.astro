---
import AdminShell from '@/layouts/AdminShell.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Alert } from '@/components/ui/alert';

export const prerender = false;
---

<AdminShell title="Settings" activeRoute="settings">
  <div class="space-y-4">
    <Card>
      <CardHeader>
        <CardTitle>Application</CardTitle>
      </CardHeader>
      <CardContent class="text-sm text-muted-foreground space-y-1">
        <p>Algorithm: <span class="text-foreground">v1-calendar-rhythm</span></p>
        <p>Confidence bands: <span class="text-foreground">low, medium</span></p>
        <p>Session TTL: <span class="text-foreground">7 days</span></p>
      </CardContent>
    </Card>
    <Alert variant="info">
      Settings are intentionally minimal. Hayd stores only the data you enter and does not integrate
      third-party trackers on authenticated pages.
    </Alert>
  </div>
</AdminShell>
